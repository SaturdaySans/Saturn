# comment
random hp 10 15
random dmg 1 3
input rounds "Rounds:"

let remaining = hp - dmg
print remaining

if remaining < 50
    print "low hp"
end

for i = 1 to rounds
    print hp
    print dmg
    if remaining > 0
        print "Rounds:"
        print i
        let remaining = remaining - dmg
        print remaining
    end
end