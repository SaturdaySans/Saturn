random hp 10 15
random dmg 1 3
input rounds "Rounds:"

let remaining = hp - dmg
print remaining

#if remaining < 50
#    print "low hp"
#end

print "Health: {hp}"
print "Damage: {dmg}"

for i = 1 to rounds
    if remaining > 0
        print "Round {i}"
        let remaining = remaining - dmg
        print "Remaining hp: {remaining}, Damage dealt: {dmg}"
    end
end